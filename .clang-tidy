Checks: '-*,cppcoreguidelines-*,readability-unused-*,bugprone-unused-*,modernize-*,performance-*,readability-identifier-naming,-cppcoreguidelines-pro-type-union-access'
HeaderFilterRegex: './src/.*'
FormatStyle: file
CheckOptions:
  - key: readability-identifier-naming.ClassCase
    value: 'CamelCase'
  - key: readability-identifier-naming.FunctionCase
    value: 'camelBack'
