Checks: '-*,cppcoreguidelines-*,readability-unused-*,bugprone-unused-*,modernize-*,performance-*'
HeaderFilterRegex: '.*'
FormatStyle: file
CheckOptions:
  - key: readability-identifier-naming.ClassCase
    value: 'CamelCase'
  - key: readability-identifier-naming.FunctionCase
    value: 'camelBack'
